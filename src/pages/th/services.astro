---
// Services page (TH)
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { t } from '@i18n/utils';

const locale = Astro.currentLocale || 'th';

const services = [
  { icon: '🏪', key: 'services.shopRental' },
  { icon: '🏢', key: 'services.meetingRoom' },
  { icon: '🚚', key: 'services.catering' },
];
---

<BaseLayout
  title={t('services.heading', locale) + ' | OpenCraft'}
  description="บริการของ OpenCraft: เช่าพื้นที่ร้าน เช่าห้องประชุม บริการเสิร์ฟนอกสถานที่"
>
  <Header />
  <main class="flex-grow theme-transition" style="background-color: var(--color-bg-primary);">
    <section class="py-20">
      <div class="container-main max-w-4xl">
        <!-- Heading -->
        <div class="text-center mb-12 page-enter">
          <h1 class="section-heading">🛎️ {t('services.heading', locale)}</h1>
          <p class="section-subheading">{t('services.subheading', locale)}</p>
        </div>

        <!-- Service 1: Shop Rental -->
        <div class="card mb-8 animate-on-scroll">
          <div class="flex items-start gap-4 mb-4">
            <span class="text-4xl">🏪</span>
            <div>
              <h3 class="text-xl font-bold mb-2" style="color: var(--color-text-heading);">เช่าพื้นที่ร้าน</h3>
              <p class="text-sm mb-4" style="color: var(--color-text-secondary);">
                เช่าพื้นที่ทั้งร้าน OpenCraft สำหรับกิจกรรมส่วนตัว ปาร์ตี้ หรืองานสังสรรค์
              </p>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="p-4 rounded-lg" style="background: var(--color-bg-card-hover);">
              <p class="text-xs font-semibold mb-1" style="color: var(--color-accent);">☀️ ช่วงกลางวัน</p>
              <p class="text-xs mb-2" style="color: var(--color-text-muted);">09:00 – 18:00 น.</p>
              <p class="text-lg font-bold" style="color: var(--color-text-heading);">10,000 บาท / 6 ชั่วโมง</p>
            </div>
            <div class="p-4 rounded-lg" style="background: var(--color-bg-card-hover);">
              <p class="text-xs font-semibold mb-1" style="color: var(--color-accent);">🌙 ช่วงกลางคืน</p>
              <p class="text-xs mb-2" style="color: var(--color-text-muted);">18:00 – 24:00 น.</p>
              <p class="text-lg font-bold" style="color: var(--color-text-heading);">15,000 บาท / 6 ชั่วโมง</p>
            </div>
          </div>
        </div>

        <!-- Service 2: Meeting Room -->
        <div class="card mb-8 animate-on-scroll">
          <div class="flex items-start gap-4 mb-4">
            <span class="text-4xl">🏢</span>
            <div>
              <h3 class="text-xl font-bold mb-2" style="color: var(--color-text-heading);">เช่าห้องประชุม</h3>
              <p class="text-sm mb-4" style="color: var(--color-text-secondary);">
                ห้องประชุมชั้น 2 รองรับได้ 20 – 30 ที่นั่ง เหมาะสำหรับเวิร์กช็อป มีตติ้ง งานนำเสนอ และกิจกรรม พร้อมจอทีวี และกระดานไวท์บอร์ด
              </p>
            </div>
          </div>

          <!-- Price -->
          <div class="p-4 rounded-lg mb-4" style="background: var(--color-bg-card-hover);">
            <p class="text-lg font-bold" style="color: var(--color-accent);">
              💰 4,000 บาท / 4 ชั่วโมง
            </p>
          </div>

          <!-- Benefits -->
          <div class="space-y-2 mb-4">
            <div class="flex items-center gap-2 text-sm" style="color: var(--color-text-secondary);">
              <span style="color: var(--color-accent);">✓</span>
              ฟรี ที่จอดรถจำนวน 2 คัน (อาคารจอดรถ โรงพยาบาลบางโพ)
            </div>
            <div class="flex items-center gap-2 text-sm" style="color: var(--color-text-secondary);">
              <span style="color: var(--color-accent);">✓</span>
              ฟรี น้ำดื่ม
            </div>
            <div class="flex items-center gap-2 text-sm" style="color: var(--color-text-secondary);">
              <span style="color: var(--color-accent);">✓</span>
              ฟรี Hi-Speed Internet 1 Gbps / 1 Gbps พร้อม Wi-Fi เวอร์ชัน 7 สุดแรง
            </div>
            <div class="flex items-center gap-2 text-sm" style="color: var(--color-text-secondary);">
              <span style="color: var(--color-accent);">✓</span>
              ได้รับส่วนลด 10% ค่าอาหาร และเครื่องดื่มแอลกอฮอล์
            </div>
          </div>

          <!-- Printer Services -->
          <h4 class="text-sm font-semibold mb-3" style="color: var(--color-text-heading);">
            🖨️ บริการเครื่องพิมพ์คุณภาพสูง รองรับการพิมพ์ภาพถ่ายได้ถึงขนาด A3 (มีค่าบริการแยก)
          </h4>
          <div class="overflow-x-auto">
            <table class="w-full text-sm" style="color: var(--color-text-secondary);">
              <thead>
                <tr style="border-bottom: 1px solid var(--color-border);">
                  <th class="text-left py-2 pr-4" style="color: var(--color-text-heading);">เอกสาร</th>
                  <th class="text-left py-2" style="color: var(--color-text-heading);">ราคา</th>
                </tr>
              </thead>
              <tbody>
                <tr style="border-bottom: 1px solid var(--color-border);">
                  <td class="py-2 pr-4">A4 ขาวดำ</td>
                  <td class="py-2">แผ่นละ 2 บาท</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--color-border);">
                  <td class="py-2 pr-4">A4 สี (ใช้น้อยกว่า 50%)</td>
                  <td class="py-2">แผ่นละ 10 บาท</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--color-border);">
                  <td class="py-2 pr-4">A4 สี (ใช้สี 50% ขึ้นไป)</td>
                  <td class="py-2">แผ่นละ 20 บาท</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--color-border);">
                  <td class="py-2 pr-4">A4 กระดาษโฟโต้ 260 แกรม</td>
                  <td class="py-2">แผ่นละ 65 บาท</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--color-border);">
                  <td class="py-2 pr-4">A3 ขาวดำ</td>
                  <td class="py-2">แผ่นละ 15 บาท</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--color-border);">
                  <td class="py-2 pr-4">A3 สี</td>
                  <td class="py-2">แผ่นละ 50 บาท</td>
                </tr>
                <tr>
                  <td class="py-2 pr-4">A3 กระดาษโฟโต้ 160 แกรม</td>
                  <td class="py-2">แผ่นละ 120 บาท</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Service 3: Catering -->
        <div class="card mb-8 animate-on-scroll">
          <div class="flex items-start gap-4 mb-4">
            <span class="text-4xl">🚚</span>
            <div>
              <h3 class="text-xl font-bold mb-2" style="color: var(--color-text-heading);">ค่าบริการนอกสถานที่</h3>
              <p class="text-sm mb-1" style="color: var(--color-text-secondary);">
                ให้บริการเฉพาะในเขตกรุงเทพ และปริมณฑล
              </p>
            </div>
          </div>

          <!-- Asahi Draft pricing -->
          <h4 class="text-sm font-semibold mb-3" style="color: var(--color-text-heading);">
            🍺 เบียร์อาซาฮีสด
          </h4>
          <div class="overflow-x-auto mb-4">
            <table class="w-full text-sm" style="color: var(--color-text-secondary);">
              <thead>
                <tr style="border-bottom: 1px solid var(--color-border);">
                  <th class="text-left py-2 pr-4" style="color: var(--color-text-heading);">จำนวนเสิร์ฟ</th>
                  <th class="text-right py-2" style="color: var(--color-text-heading);">ราคา</th>
                </tr>
              </thead>
              <tbody>
                <tr style="border-bottom: 1px solid var(--color-border);">
                  <td class="py-2 pr-4">150 เสิร์ฟ</td>
                  <td class="py-2 text-right font-semibold" style="color: var(--color-accent);">12,000 บาท</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--color-border);">
                  <td class="py-2 pr-4">200 เสิร์ฟ</td>
                  <td class="py-2 text-right font-semibold" style="color: var(--color-accent);">15,000 บาท</td>
                </tr>
                <tr style="border-bottom: 1px solid var(--color-border);">
                  <td class="py-2 pr-4">250 เสิร์ฟ</td>
                  <td class="py-2 text-right font-semibold" style="color: var(--color-accent);">18,000 บาท</td>
                </tr>
                <tr>
                  <td class="py-2 pr-4">300 เสิร์ฟ</td>
                  <td class="py-2 text-right font-semibold" style="color: var(--color-accent);">21,000 บาท</td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Other offerings -->
          <div class="space-y-2">
            <div class="flex items-center gap-2 text-sm" style="color: var(--color-text-secondary);">
              <span style="color: var(--color-accent);">🍺</span>
              เบียร์คราฟต์กระป๋องและขวด ตามงบประมาณที่ตกลงกัน
            </div>
            <div class="flex items-center gap-2 text-sm" style="color: var(--color-text-secondary);">
              <span style="color: var(--color-accent);">🍷</span>
              ไวน์ ตามงบประมาณที่ตกลงกัน
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div class="text-center mt-12 animate-on-scroll">
          <div class="card inline-block max-w-md mx-auto glow-accent">
            <p class="text-lg font-semibold mb-4" style="color: var(--color-text-heading);">
              {t('services.inquiryCta', locale)}
            </p>
            <a href="mailto:hi@opencraft.bar" class="btn-primary">
              📧 hi@opencraft.bar
            </a>
            <p class="text-sm mt-3" style="color: var(--color-text-muted);">
              📱 <a href="tel:0924129992" style="color: var(--color-accent);">092-412-9992</a>
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
