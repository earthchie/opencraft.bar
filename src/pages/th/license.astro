---
// License page (TH) — OpenCraft Brand License v1.0.0
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { t } from '@i18n/utils';

const locale = Astro.currentLocale || 'th';
---

<BaseLayout
  title="สัญญาอนุญาตให้ใช้แบรนด์ OpenCraft v1.0.0 | OpenCraft"
  description="OpenCraft Brand License — สัญญาอนุญาตให้ใช้แบรนด์ OpenCraft สำหรับชุมชน ข้อกำหนด มาตรฐาน และแนวทางการใช้งาน"
>
  <Header />
  <main class="flex-grow theme-transition" style="background-color: var(--color-bg-primary);">
    <section class="py-20">
      <div class="container-main max-w-4xl">
        <a href="/th/about/" class="inline-flex items-center gap-1 text-sm mb-8 transition-colors" style="color: var(--color-text-muted);">
          ← กลับไปหน้าเกี่ยวกับ
        </a>

        <article class="prose prose-lg max-w-none" style="color: var(--color-text-primary);">
          <h1>สัญญาอนุญาตให้ใช้แบรนด์ OpenCraft</h1>
          <p class="text-lg" style="color: var(--color-text-secondary);"><em>OpenCraft Brand License v1.0.0</em></p>

          <hr />

          <h2>1. วัตถุประสงค์</h2>
          <p>OpenCraft คือแบรนด์เปิดสำหรับผู้ที่เชื่อว่างานคราฟต์ วัฒนธรรมเปิด ชุมชนท้องถิ่น และการดำเนินกิจการอย่างรับผิดชอบ สามารถเติบโตไปด้วยกันได้</p>
          <p>OpenCraft มีแนวคิดหลักภายใต้ tagline <strong>Where Craft Meets Open Culture</strong></p>
          <p>ในบริบทของ OpenCraft คำว่า <strong>Craft</strong> ไม่ได้จำกัดอยู่เฉพาะเบียร์ อาหาร หรือสินค้าแฮนด์เมด แต่หมายถึงสินค้า บริการ ประสบการณ์ พื้นที่ กิจกรรม หรือองค์ความรู้ที่เกิดจากความตั้งใจ คุณภาพ ความซื่อสัตย์ และความเคารพต่อผู้สร้าง ผู้ให้บริการ ลูกค้า และชุมชน</p>
          <p><strong>Open Culture</strong> หมายถึงวัฒนธรรมที่เปิดให้ผู้คนเรียนรู้ แบ่งปัน ทดลอง ดัดแปลง ร่วมสร้าง และพัฒนาต่อได้ โดยยังเคารพที่มา ความรับผิดชอบ และความปลอดภัยของชุมชน</p>
          <p>OpenCraft จึงไม่จำกัดอยู่เฉพาะร้านเบียร์ บาร์ หรือร้านอาหาร แต่สามารถนำไปใช้กับกิจการหลากหลายรูปแบบ เช่น คาเฟ่ ร้านอาหาร บาร์ ร้านเครื่องดื่ม ร้านหนังสือ พื้นที่กิจกรรม เวิร์กช็อป สตูดิโอ maker space coworking space ร้านสินค้าคราฟต์ ชุมชนออนไลน์ pop-up event หรือกิจการรูปแบบอื่นที่สอดคล้องกับหลักการของ OpenCraft</p>
          <p>สัญญาอนุญาตฉบับนี้อนุญาตให้บุคคลทั่วไปสามารถเปิดร้าน ดำเนินกิจการ ดัดแปลง แตกแขนง หรือพัฒนาแนวคิดของ OpenCraft ต่อไปได้ ตราบเท่าที่ยังปฏิบัติตามมาตรฐานขั้นต่ำและเงื่อนไขที่กำหนดไว้ในเอกสารฉบับนี้</p>
          <p>เป้าหมายของ OpenCraft ไม่ใช่การสร้างระบบแฟรนไชส์ แต่คือการสร้างแบรนด์เปิดที่ชุมชนสามารถนำไปใช้ ดัดแปลง ทดลอง และพัฒนาต่อได้อย่างอิสระ โดยยังรักษาความซื่อสัตย์ ความรับผิดชอบ และคุณค่าร่วมของแบรนด์</p>

          <hr />

          <h2>2. คำนิยาม</h2>
          <p><strong>OpenCraft</strong> — ชื่อ OpenCraft โลโก้ อัตลักษณ์ทางภาพ สโลแกน tagline ภาษาการออกแบบ เอกสารแบรนด์ คู่มือการดำเนินงาน รูปแบบเมนู รูปแบบกิจกรรม และสื่ออื่นใดที่เผยแพร่โดย OpenCraft Core Team</p>
          <p><strong>Tagline</strong> — ข้อความประจำแบรนด์ OpenCraft คือ "Where Craft Meets Open Culture" หรือข้อความอื่นใดที่ Core Team ประกาศให้เป็น tagline อย่างเป็นทางการในอนาคต</p>
          <p><strong>OpenCraft Venue</strong> — ร้าน พื้นที่ กิจการ ชุมชน กิจกรรม หรือแพลตฟอร์มใด ๆ ที่ใช้ชื่อ OpenCraft หรือแสดงตนว่าเป็นส่วนหนึ่งของระบบนิเวศ OpenCraft</p>
          <p><strong>Craft</strong> — สินค้า บริการ ประสบการณ์ งานสร้างสรรค์ องค์ความรู้ หรือกิจกรรมที่มีความตั้งใจ มีคุณภาพ มีที่มา มีเรื่องราว และเคารพต่อผู้สร้าง ผู้ให้บริการ ลูกค้า และชุมชน</p>
          <p><strong>Open Culture</strong> — วัฒนธรรมที่สนับสนุนการเรียนรู้ร่วมกัน การแบ่งปันความรู้ การเปิดให้ดัดแปลง การมีส่วนร่วมของชุมชน ความโปร่งใส และการพัฒนาต่อยอดอย่างรับผิดชอบ</p>
          <p><strong>Fork</strong> — การนำแนวคิด แบรนด์ รูปแบบร้าน เอกสาร หรือสื่อของ OpenCraft ไปดัดแปลง ใช้งาน หรือพัฒนาต่อโดยผู้ดำเนินการรายอื่น พื้นที่อื่น ชุมชนอื่น หรือทีมอื่น</p>
          <p><strong>Operator</strong> — บุคคล บริษัท กลุ่มบุคคล องค์กร หรือหน่วยงานใดที่ใช้แบรนด์ OpenCraft ภายใต้สัญญาอนุญาตฉบับนี้</p>
          <p><strong>Core Team</strong> — ผู้ดูแลแบรนด์ OpenCraft ดั้งเดิม หรือกลุ่มผู้สืบทอดที่ได้รับมอบหมายให้ดูแลแบรนด์ สัญญาอนุญาต และทะเบียนสาธารณะของ OpenCraft</p>
          <p><strong>Brand Materials</strong> — โลโก้ ชื่อแบรนด์ tagline กราฟิก เทมเพลต เมนู โปสเตอร์ เอกสาร เว็บไซต์ มาสคอต คู่มือแบรนด์ คู่มือการดำเนินงาน คู่มือฝึกอบรม หรือสื่ออื่นใดที่เผยแพร่โดย Core Team</p>

          <hr />

          <h2>3. สิทธิที่ได้รับอนุญาต</h2>
          <p>ภายใต้เงื่อนไขของสัญญาอนุญาตฉบับนี้ Core Team อนุญาตให้ Operator ใช้ชื่อ OpenCraft และ Brand Materials ได้แบบไม่ผูกขาด ใช้ได้ทั่วโลก ไม่มีค่าลิขสิทธิ์ และสามารถเพิกถอนได้ หากมีการฝ่าฝืนเงื่อนไข</p>
          <p>Operator สามารถดำเนินการดังต่อไปนี้ได้:</p>
          <ol>
            <li>ใช้ชื่อ OpenCraft กับชื่อร้าน ชื่องาน เมนู ป้าย เว็บไซต์ สื่อสังคมออนไลน์ หรือสื่อประชาสัมพันธ์</li>
            <li>ใช้โลโก้และองค์ประกอบทางภาพของ OpenCraft ตามแนวทางการใช้แบรนด์</li>
            <li>ใช้ tagline "Where Craft Meets Open Culture" ร่วมกับแบรนด์ OpenCraft</li>
            <li>แก้ไข ดัดแปลง แปล ปรับให้เข้ากับท้องถิ่น หรือ remix Brand Materials เพื่อใช้งานในพื้นที่ของตน</li>
            <li>สร้าง Fork ของ OpenCraft สำหรับเมือง ย่าน ชุมชน รูปแบบกิจกรรม รูปแบบร้าน หรือรูปแบบกิจการเฉพาะ</li>
            <li>แบ่งปันการปรับปรุง เทมเพลต คู่มือ รูปแบบกิจกรรม วิธีดำเนินงาน หรือองค์ความรู้กลับสู่ชุมชน OpenCraft</li>
          </ol>
          <p>สัญญาอนุญาตฉบับนี้ไม่ก่อให้เกิดความสัมพันธ์ในลักษณะแฟรนไชส์ ตัวแทน ลูกจ้าง หุ้นส่วน กิจการร่วมค้า หรือการลงทุนร่วมกันระหว่าง Operator กับ Core Team</p>

          <hr />

          <h2>4. มาตรฐานขั้นต่ำของ OpenCraft</h2>

          <h3>4.1 วัฒนธรรมเปิด</h3>
          <p>Operator ต้องสนับสนุนวัฒนธรรมเปิด การแบ่งปันความรู้ และการมีส่วนร่วมของชุมชน OpenCraft Venue ควรเป็นพื้นที่ที่ผู้คนสามารถเรียนรู้ พูดคุย ทดลอง สร้างสรรค์ ชิม ใช้งาน แบ่งปัน และพบปะกันด้วยเจตนาดี</p>

          <h3>4.2 งานคราฟต์และความตั้งใจ</h3>
          <p>Operator ควรให้ความสำคัญกับสินค้า บริการ หรือประสบการณ์ที่มีคุณภาพ มีความตั้งใจ มีที่มา และไม่หลอกลวงผู้บริโภค OpenCraft ไม่จำเป็นต้องจำกัดอยู่ที่เบียร์หรือเครื่องดื่ม แต่ควรมีจุดยืนเรื่องความใส่ใจ ความโปร่งใส และความเคารพต่อผู้สร้าง ผู้ให้บริการ ลูกค้า และชุมชน</p>

          <h3>4.3 ความโปร่งใสของสินค้าและบริการ</h3>
          <p>Operator ควรให้ข้อมูลที่ชัดเจนและไม่ทำให้เข้าใจผิดเกี่ยวกับสินค้า บริการ ราคา แหล่งที่มา ส่วนประกอบ เงื่อนไขการให้บริการ และข้อจำกัดที่สำคัญ หากสินค้าหรือบริการมีความเสี่ยงเฉพาะ เช่น แอลกอฮอล์ อาหาร สารก่อภูมิแพ้ กิจกรรมทางกาย อุปกรณ์ เครื่องมือ หรือบริการที่ต้องใช้ความระมัดระวัง Operator ควรแจ้งข้อมูลที่จำเป็นต่อผู้ใช้บริการอย่างเหมาะสม</p>

          <h3>4.4 การดำเนินกิจการอย่างรับผิดชอบ</h3>
          <p>Operator ต้องปฏิบัติตามกฎหมายและกฎระเบียบที่เกี่ยวข้องกับกิจการของตน เช่น ใบอนุญาตประกอบกิจการ ภาษี แรงงาน ความปลอดภัย อาหาร เครื่องดื่ม สาธารณสุข การคุ้มครองผู้บริโภค การโฆษณา ทรัพย์สินทางปัญญา และกฎหมายท้องถิ่นอื่นที่เกี่ยวข้อง</p>

          <h3>4.5 การให้บริการเครื่องดื่มแอลกอฮอล์อย่างรับผิดชอบ</h3>
          <p>หาก OpenCraft Venue มีการจำหน่ายหรือให้บริการเครื่องดื่มแอลกอฮอล์ Operator ต้องปฏิบัติตามกฎหมายและกฎระเบียบที่เกี่ยวข้องทั้งหมด Operator ต้องไม่จำหน่ายหรือส่งเสริมการบริโภคเครื่องดื่มแอลกอฮอล์ในลักษณะที่สนับสนุนการบริโภคที่ไม่ปลอดภัย ผิดกฎหมาย หรือขาดความรับผิดชอบ</p>

          <h3>4.6 ความปลอดภัยของชุมชน</h3>
          <p>Operator ต้องรักษาพื้นที่ให้ปลอดภัย เป็นมิตร และไม่เอื้อต่อการคุกคามหรือการละเมิด การเลือกปฏิบัติ การแสวงหาประโยชน์โดยมิชอบ หรือการกระทำที่รู้ว่าไม่ปลอดภัย ไม่สอดคล้องกับแบรนด์ OpenCraft</p>

          <h3>4.7 ความเป็นอิสระของแต่ละพื้นที่</h3>
          <p>OpenCraft Venue แต่ละแห่งเป็นกิจการที่ดำเนินการโดยอิสระ Operator ต้องไม่กล่าวอ้างว่าเป็นเจ้าของเดียวกัน อยู่ภายใต้การบริหาร ได้รับการรับรอง ได้รับการกำกับดูแล หรือได้รับการสนับสนุนอย่างเป็นทางการจาก Core Team เว้นแต่ได้รับอนุญาตเป็นลายลักษณ์อักษร</p>

          <h3>4.8 ความซื่อสัตย์ในการใช้แบรนด์</h3>
          <p>Operator ต้องไม่ใช้แบรนด์ OpenCraft ในลักษณะที่ทำให้สาธารณชนสับสน และต้องแสดงสถานะของตนให้ชัดเจน เช่น "OpenCraft Community Fork" "Inspired by OpenCraft" "Formerly OpenCraft" หรือสถานะอื่นที่ได้รับอนุมัติจาก Core Team</p>

          <h3>4.9 การดำเนินกิจการโดยชอบด้วยกฎหมายและจริยธรรม</h3>
          <p>Operator ต้องดำเนินกิจการอย่างถูกต้องตามกฎหมายและมีจริยธรรม ห้ามใช้แบรนด์ OpenCraft เพื่อการฉ้อโกง การจำหน่ายสินค้าหรือบริการที่ผิดกฎหมาย การให้บริการแอลกอฮอล์แก่ผู้มีอายุต่ำกว่ากฎหมายกำหนด กิจกรรมที่ไม่ปลอดภัย การโฆษณาหลอกลวง สินค้าปลอม กิจกรรมที่สร้างความเกลียดชัง ความรุนแรงทางการเมือง หรือการกระทำที่ก่อให้เกิดความเสียหายอย่างมีนัยสำคัญต่อชุมชน OpenCraft</p>

          <hr />

          <h2>5. หลักเกณฑ์การใช้แบรนด์</h2>

          <h3>5.1 การใช้งานที่ได้รับอนุญาต</h3>
          <p>Operator สามารถใช้ชื่อ OpenCraft และ Brand Materials สำหรับป้ายร้าน เมนู สื่อสังคมออนไลน์ เว็บไซต์ โปสเตอร์กิจกรรม เอกสารฝึกอบรม สินค้าที่ระลึก กิจกรรมชุมชน การดัดแปลงให้เข้ากับท้องถิ่น และการอธิบายแนวคิด OpenCraft ต่อสาธารณะ</p>

          <h3>5.2 การแสดงที่มา</h3>
          <p>Fork อิสระควรแสดงข้อความระบุที่มาในตำแหน่งที่เหมาะสม เช่น ส่วนท้ายเว็บไซต์ เมนู โปสเตอร์ หรือโปรไฟล์สาธารณะ</p>
          <p><strong>ข้อความภาษาไทย:</strong> "OpenCraft เป็นแบรนด์เปิด สถานที่นี้เป็น community fork อิสระ ที่บริหารงานภายใต้ OpenCraft Brand License"</p>
          <p><strong>ข้อความภาษาอังกฤษ:</strong> "OpenCraft is an open brand. This venue is an independent community fork operating under the OpenCraft Brand License."</p>

          <hr />

          <h2>6. การตั้งชื่อ Fork</h2>
          <p>Fork สามารถใช้ชื่อในลักษณะ: OpenCraft Chiang Mai, OpenCraft Phuket, OpenCraft Community Fork Bangkok, OpenCraft Lab, OpenCraft Pop-up, OpenCraft Market, OpenCraft Studio, OpenCraft Books, OpenCraft Café, OpenCraft Night Market Edition หรือลักษณะอื่นที่คล้ายคลึง</p>

          <hr />

          <h2>7. สถานะทางการ</h2>
          <p>Core Team อาจจัดทำทะเบียนสาธารณะของ OpenCraft Venue และ Fork ต่าง ๆ การมีชื่ออยู่ในทะเบียนไม่ได้หมายความว่าสถานที่นั้นเป็นเจ้าของเดียวกัน อยู่ภายใต้การบริหารเดียวกัน ได้รับการรับประกัน ได้รับการรับรอง หรือได้รับการสนับสนุนทางการเงินจาก Core Team โดยอัตโนมัติ</p>

          <hr />

          <h2>8. การมีส่วนร่วมกลับสู่ชุมชน</h2>
          <p>Operator ได้รับการสนับสนุนให้แบ่งปันสิ่งที่พัฒนาขึ้นกลับสู่ชุมชน OpenCraft เช่น เทมเพลตเมนู การ์ดชิม รูปแบบกิจกรรม เอกสารฝึกอบรม ข้อมูลซัพพลายเออร์ สื่อความรู้ ซอฟต์แวร์โอเพนซอร์ส ไฟล์ออกแบบ เช็กลิสต์การดำเนินงาน และบทเรียนจากการดำเนินกิจการ</p>

          <hr />

          <h2>9. การตรวจสอบคุณภาพและความปลอดภัย</h2>
          <p>Core Team สามารถตรวจสอบการใช้แบรนด์ OpenCraft ที่ปรากฏต่อสาธารณะได้ หากพบการฝ่าฝืน Operator ควรแก้ไขภายใน 30 วัน ในกรณีฝ่าฝืนอย่างร้ายแรง Core Team สามารถระงับหรือยุติสัญญาอนุญาตได้ทันที</p>

          <hr />

          <h2>10. การระงับและการยุติสัญญาอนุญาต</h2>
          <p>สัญญาอนุญาตฉบับนี้จะสิ้นสุดโดยอัตโนมัติ หาก Operator ฝ่าฝืนเงื่อนไขอย่างมีนัยสำคัญและไม่แก้ไขภายในระยะเวลาที่กำหนด หลังจากสิ้นสุด Operator ต้องหยุดใช้ชื่อ OpenCraft โลโก้ tagline และ Brand Materials ในลักษณะที่ทำให้เข้าใจว่ายังคงมีสถานะเป็น OpenCraft อยู่</p>

          <hr />

          <h2>11. ไม่มีการรับประกัน</h2>
          <p>แบรนด์ OpenCraft และ Brand Materials จัดให้มีตามสภาพที่เป็นอยู่ Core Team ไม่รับประกันผลกำไร ความถูกต้องตามกฎหมาย ความต้องการของลูกค้า หรือการอนุมัติจากหน่วยงานกำกับดูแล Operator แต่ละรายมีหน้าที่รับผิดชอบต่อธุรกิจของตนเอง</p>

          <hr />

          <h2>12. การจำกัดความรับผิด</h2>
          <p>ภายใต้ขอบเขตสูงสุดที่กฎหมายอนุญาต Core Team ไม่ต้องรับผิดชอบต่อความสูญเสีย ความเสียหาย ข้อเรียกร้อง หรือผลใด ๆ ที่เกิดจากการใช้แบรนด์ OpenCraft Operator แต่ละรายตกลงรับผิดชอบต่อการกระทำของตนเอง</p>

          <hr />

          <h2>13. ไม่มีการโอนกรรมสิทธิ์</h2>
          <p>สัญญาอนุญาตฉบับนี้ไม่เป็นการโอนกรรมสิทธิ์ในชื่อ OpenCraft เครื่องหมายการค้า โลโก้ tagline หรือ Brand Materials Operator ต้องไม่พยายามอ้างสิทธิผูกขาดเหนือแบรนด์ OpenCraft</p>

          <hr />

          <h2>14. กฎหมายท้องถิ่น</h2>
          <p>สัญญาอนุญาตฉบับนี้มีเจตนาให้ตีความในลักษณะที่สนับสนุนความร่วมมือแบบเปิด พร้อมกับรักษาความสมบูรณ์และชื่อเสียงของแบรนด์ OpenCraft</p>

          <hr />

          <h2>15. การจัดการเวอร์ชัน</h2>
          <p>Core Team อาจปรับปรุงสัญญาอนุญาตฉบับนี้เป็นครั้งคราว Operator สามารถใช้เวอร์ชันที่ตนเริ่มใช้งานต่อไปได้ เว้นแต่กรณีจำเป็น</p>

