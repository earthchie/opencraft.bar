---
// Footer component
import Logo from './Logo.astro';
import { t } from '@i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

const locale = Astro.currentLocale || 'en';
const homeUrl = getRelativeLocaleUrl(locale, '');

const quickLinks = [
  { key: 'nav.home', href: getRelativeLocaleUrl(locale, '') },
  { key: 'nav.tapList', href: getRelativeLocaleUrl(locale, '') + '#tap-list' },
  { key: 'nav.news', href: getRelativeLocaleUrl(locale, 'news') },
  { key: 'nav.knowledge', href: getRelativeLocaleUrl(locale, 'knowledge') },
  { key: 'nav.location', href: getRelativeLocaleUrl(locale, 'location') },
  { key: 'nav.services', href: getRelativeLocaleUrl(locale, 'services') },
  { key: 'nav.about', href: getRelativeLocaleUrl(locale, 'about') },
];
---

<footer class="theme-transition" style="background-color: var(--color-bg-footer); color: var(--color-text-secondary);">
  <div class="container-main py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <a href={homeUrl} class="flex items-center gap-2 mb-3">
          <Logo variant="icon" size="sm" className="brightness-0 invert" />
          <Logo variant="wordmark" size="sm" className="brightness-0 invert" />
        </a>
        <p class="text-sm leading-relaxed opacity-80" style="color: var(--color-text-muted);">
          {t('footer.tagline', locale)}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold mb-3 uppercase tracking-wider" style="color: var(--color-accent);">
          {t('footer.quickLinks', locale)}
        </h3>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm opacity-80 hover:opacity-100 transition-opacity" style="color: var(--color-text-muted);">
                {t(link.key, locale)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social / Contact -->
      <div>
        <h3 class="text-sm font-semibold mb-3 uppercase tracking-wider" style="color: var(--color-accent);">
          {t('footer.followUs', locale)}
        </h3>
        <div class="flex gap-3">
          <a href="https://www.facebook.com/opencraft.bar" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full flex items-center justify-center transition-all duration-200"
             style="background-color: var(--color-bg-secondary); color: var(--color-text-muted);"
             aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-full flex items-center justify-center transition-all duration-200"
             style="background-color: var(--color-bg-secondary); color: var(--color-text-muted);"
             aria-label="X / Twitter">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-10 pt-6 border-t text-center text-xs" style="border-color: rgba(255,255,255,0.1); color: var(--color-text-muted);">
      <p>{t('footer.copyright', locale)}</p>
      <p class="mt-1 opacity-60">{t('footer.craftedWith', locale)}</p>
    </div>
  </div>
</footer>
