---
// Home page (EN)
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import HeroSection from '@components/HeroSection.astro';
import TapList from '@components/TapList.astro';
import NewsSection from '@components/NewsSection.astro';
import KnowledgeSection from '@components/KnowledgeSection.astro';
import Footer from '@components/Footer.astro';
---

<BaseLayout
  title="OpenCraft — Craft Beer Bar"
  description="OpenCraft — Where Craft Meets Open Culture. A craft beer bar in Thailand with rotating taps, events, and beer knowledge."
>
  <Header />
  <main>
    <HeroSection />
    <TapList />
    <NewsSection />
    <KnowledgeSection />
  </main>
  <Footer />
</BaseLayout>
