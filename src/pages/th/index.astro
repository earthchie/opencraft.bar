---
// Home page (TH)
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import HeroSection from '@components/HeroSection.astro';
import TapList from '@components/TapList.astro';
import NewsSection from '@components/NewsSection.astro';
import KnowledgeSection from '@components/KnowledgeSection.astro';
import Footer from '@components/Footer.astro';
---

<BaseLayout
  title="OpenCraft — คราฟต์เบียร์บาร์"
  description="OpenCraft — ที่ซึ่งคราฟต์เบียร์มาพบกับวัฒนธรรมเปิด คราฟต์เบียร์บาร์ในประเทศไทยพร้อมเบียร์สดหมุนเวียน กิจกรรม และความรู้เรื่องเบียร์"
>
  <Header />
  <main>
    <HeroSection />
    <TapList />
    <NewsSection />
    <KnowledgeSection />
  </main>
  <Footer />
</BaseLayout>
