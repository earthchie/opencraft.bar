---
// LanguageSwitcher — toggle between EN and TH
import { getRelativeLocaleUrl } from 'astro:i18n';
import { t } from '@i18n/utils';

const currentLocale = Astro.currentLocale || 'th';
const isEN = currentLocale === 'en';
const targetLocale = isEN ? 'th' : 'en';

// Strip locale prefix from current path to get the clean path
let cleanPath = Astro.url.pathname;
if (isEN) {
  // Currently at /en/... — strip /en prefix
  cleanPath = cleanPath.replace(/^\/en(\/|$)/, '/');
} else {
  // Currently at /... or /th/... — strip /th prefix if present
  cleanPath = cleanPath.replace(/^\/th(\/|$)/, '/');
}
cleanPath = cleanPath.replace(/^\/+$/, '') || '';

const switchUrl = getRelativeLocaleUrl(targetLocale, cleanPath);
---

<a
  href={switchUrl}
  class="lang-switch flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium transition-all duration-300"
  style="color: var(--color-text-secondary); border: 1px solid var(--color-border);"
  aria-label={isEN ? t('common.switchToTH', 'en') : t('common.switchToEN', 'th')}
>
  <span class="text-base">{isEN ? '🇹🇭' : '🇬🇧'}</span>
  <span class="hidden sm:inline">{isEN ? 'ไทย' : 'EN'}</span>
</a>
