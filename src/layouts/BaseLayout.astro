---
// BaseLayout — HTML shell with SEO, theme, fonts, global styles
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const { title = 'OpenCraft', description = "OpenCraft — Where Craft Meets Open Culture", ogImage = '/og.png' } = Astro.props;

// Construct full OG image URL
const siteUrl = 'https://opencraft.bar';
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

// Import global styles (bundled by Astro at build time)
import '/src/styles/base.css';
import '/src/styles/animations.css';
---

<!DOCTYPE html>
<html lang={Astro.currentLocale || 'en'} data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#c8934f" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={fullOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="OpenCraft" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={fullOgImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/images/logos/OpenCraft_Icon_Gold.png" />

  <!-- Fonts: Inter + Noto Sans Thai + Playfair Display (tagline) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Noto+Sans:wght@400;500;600;700;800;900&family=Noto+Sans+Thai:wght@400;500;600;700&family=Dancing+Script:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <title>{title} | OpenCraft</title>

  <!-- Pagefind search UI (includes pagefind core) -->
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>

  <!-- Inline theme script — runs before paint to prevent FOUC -->
  <script is:inline>
    (function() {
      var theme = localStorage.getItem('opencraft-theme') || 'dark';
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
</head>
<body class="min-h-screen flex flex-col antialiased theme-transition">
  <slot />

  <!-- Scroll-triggered animation observer -->
  <script>
    // Intersection Observer for scroll animations
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );

    document.querySelectorAll('.animate-on-scroll, .stagger-children').forEach((el) => {
      observer.observe(el);
    });

    // Re-observe after page swaps
    document.addEventListener('astro:after-swap', () => {
      document.querySelectorAll('.animate-on-scroll, .stagger-children').forEach((el) => {
        observer.observe(el);
      });
    });
  </script>

  <!-- Mermaid diagram renderer -->
  <script>
    import '../scripts/mermaid-init.ts';
  </script>
</body>
</html>
